{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Independent code review",
  "type": "object",
  "additionalProperties": false,
  "required": ["verdict", "summary", "findings", "verification_gaps", "acceptance_criteria_assessment", "confidence"],
  "properties": {
    "verdict": {"enum": ["pass", "changes_required", "blocked"]},
    "summary": {"type": "string"},
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "severity", "category", "file", "line_start", "description", "evidence", "recommended_fix"],
        "properties": {
          "id": {"type": "string", "pattern": "^F-[0-9]+$"},
          "severity": {"enum": ["critical", "high", "medium", "low"]},
          "category": {"enum": ["correctness", "security", "reliability", "performance", "maintainability", "testing", "compatibility", "documentation"]},
          "file": {"type": ["string", "null"]},
          "line_start": {"type": ["integer", "null"], "minimum": 1},
          "description": {"type": "string"},
          "evidence": {"type": "string"},
          "recommended_fix": {"type": "string"}
        }
      }
    },
    "verification_gaps": {"type": "array", "items": {"type": "string"}},
    "acceptance_criteria_assessment": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "status", "evidence"],
        "properties": {
          "id": {"type": "string"},
          "status": {"enum": ["satisfied", "partially_satisfied", "not_satisfied", "not_verifiable"]},
          "evidence": {"type": "string"}
        }
      }
    },
    "confidence": {"type": "number", "minimum": 0, "maximum": 1}
  }
}
